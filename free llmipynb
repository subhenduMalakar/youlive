        "### Load Testing: 20 Consecutive Requests\n",
        "This cell will perform 20 requests per model using a query designed to elicit longer responses to test stability and rate limits."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "07612de9",
        "outputId": "870622ac-2165-4bb0-9241-38c3410d1fac"
      },
      "source": [
        "import time\n",
        "import random\n",
        "\n",
        "def run_stress_test(name, client, model_name):\n",
        "    print(f\"--- Starting Stress Test for {name} ---\")\n",
        "    query = \"Explain the theory of relativity in great detail, including its historical context and impact on modern physics.\"\n",
        "    success_count = 0\n",
        "\n",
        "    for i in range(1, 21):\n",
        "        retries = 3\n",
        "        while retries > 0:\n",
        "            try:\n",
        "                start_time = time.time()\n",
        "                response = client.chat.completions.create(\n",
        "                    model=model_name,\n",
        "                    messages=[{\"role\": \"user\", \"content\": query}],\n",
        "                    max_tokens=500\n",
        "                )\n",
        "                duration = time.time() - start_time\n",
        "                success_count += 1\n",
        "                print(f\"[Call {i}] Success ({duration:.2f}s). Response length: {len(response.choices[0].message.content)} chars\")\n",
        "                break # Exit retry loop on success\n",
        "            except Exception as e:\n",
        "                if \"429\" in str(e):\n",
        "                    wait = (4 - retries) * 5 + random.uniform(1, 3)\n",
        "                    print(f\"[Call {i}] Rate limited (429). Retrying in {wait:.1f}s...\")\n",
        "                    time.sleep(wait)\n",
        "                    retries -= 1\n",
        "                else:\n",
        "                    print(f\"[Call {i}] Failed: {e}\")\n",
        "                    break\n",
        "\n",
        "        # Standard delay between calls to be safe\n",
        "        time.sleep(2)\n",
        "\n",
        "    print(f\"--- {name} Test Complete: {success_count}/20 successful ---\\n\")\n",
        "\n",
        "# Run test for DeepSeek specifically as Gemini is currently rate-limited\n",
        "run_stress_test(\"DeepSeek Chat\", client_deepseek, \"deepseek-chat\")"
      ],
